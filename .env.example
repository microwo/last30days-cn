# Environment variables for last30days-cn
# Copy this file to .env and fill in your API keys

# Zhihu API (Kuaidaili)
# Get your API key from: https://www.kuaidaili.com/
ZHIHU_API_KEY=your_kuaidaili_api_key_here

# Optional: Backend selection for Zhihu (default: kuaidaili)
# Options: kuaidaili, official, custom
ZHIHU_BACKEND=kuaidaili

# Xiaohongshu API (Kuaidaili) - To be implemented
XIAOHONGSHU_API_KEY=your_kuaidaili_api_key_here

# Weibo API - To be implemented
WEIBO_API_KEY=your_weibo_api_key_here

# Douyin API - To be implemented
DOUYIN_API_KEY=your_douyin_api_key_here
